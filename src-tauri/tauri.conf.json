{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevToolkit",
  "version": "0.1.0",
  "identifier": "com.devtoolkit.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1OEUyOTNERjk1Nzk0N0MKUldGN2NuVjN6VDU1c05OVWFScWRiTXpCaXREZFgrMUxOTUFUNDVUUXNCZ3lISnJhN1lxcUtzWmsK",
      "endpoints": [
        "https://github.com/yorickshan/devtoolkit/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "DevToolkit",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
