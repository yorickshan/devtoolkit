{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for DevToolkit",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "clipboard-manager:default",
    "sql:default",
    "notification:default",
    "log:default",
    "process:default",
    "shell:default",
    "opener:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:event:default",
    "core:menu:default",
    "core:tray:default",
    "window-state:default"
  ]
}
